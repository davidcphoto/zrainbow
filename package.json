{
  "name": "zrainbow",
  "displayName": "zRainbow",
  "description": "Color pairing of if, perform, evaluate conditions for COBOL programs",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.60.0"
  },
  "icon": "zRainbow.png",
  "categories": [
    "Other"
  ],
  "keywords": [
    "cobol",
    "rainbow",
    "syntax highlighting",
    "brackets",
    "if",
    "perform",
    "evaluate",
    "end-if",
    "end-perform",
    "end-evaluate",
    "else",
    "when",
    "color",
    "nesting",
    "visual studio code",
    "extension",
    "zowe",
    "zos",
    "z/os",
    "mainframe",
    "IBM",
    "AS400",
    "IBM i"
  ],
  "activationEvents": [
    "onLanguage:cobol",
    "onLanguage:COBOL"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "zrainbow.toggle",
        "title": "zRainbow: Toggle COBOL Rainbow Brackets"
      }
    ],
    "configuration": {
      "title": "zRainbow",
      "properties": {
        "zrainbow.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable rainbow coloring for COBOL conditional structures"
        },
        "zrainbow.colors": {
          "type": "array",
          "default": [
            { "opening": "#FFD700", "middle": "#FFA500", "closing": "#FFD700" },
            { "opening": "#00CED1", "middle": "#1E90FF", "closing": "#00CED1" },
            { "opening": "#FF69B4", "middle": "#FF1493", "closing": "#FF69B4" },
            { "opening": "#32CD32", "middle": "#228B22", "closing": "#32CD32" },
            { "opening": "#9370DB", "middle": "#8B008B", "closing": "#9370DB" },
            { "opening": "#FF6347", "middle": "#DC143C", "closing": "#FF6347" }
          ],
          "description": "Colors for different nesting levels. Each level has opening, middle (ELSE/WHEN), and closing colors.",
          "items": {
            "type": "object",
            "properties": {
              "opening": {
                "type": "string",
                "description": "Color for opening keywords (IF, PERFORM, EVALUATE)"
              },
              "middle": {
                "type": "string",
                "description": "Color for middle keywords (ELSE, WHEN)"
              },
              "closing": {
                "type": "string",
                "description": "Color for closing keywords (END-IF, END-PERFORM, END-EVALUATE)"
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "node ./test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "@types/mocha": "^10.0.2",
    "@types/node": "18.x",
    "eslint": "^8.50.0",
    "glob": "^10.3.3",
    "mocha": "^10.2.0",
    "typescript": "^5.2.2",
    "@vscode/test-electron": "^2.3.4"
  }
}
